NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI Director (server-only; OpenAI-compatible Logicc endpoint)
LOGICC_API_KEY=
LOGICC_BASE_URL=
LOGICC_MODEL=default

# Explicit, opt-in AI Director failover. Credentials alone never enable it.
AI_DIRECTOR_FALLBACK_PROVIDER=
LANGDOCK_API_KEY=
LANGDOCK_BASE_URL=https://api.langdock.com/openai/eu/v1
LANGDOCK_MODEL=default

# Offline production providers (never expose these to the Unity APK)
MESHY_AI_API=
MESHY_BASE_URL=https://api.meshy.ai
BLACKBOX_API_KEY=
BLACKBOX_BASE_URL=https://api.blackbox.ai
BLACKBOX_IMAGE_MODEL=flux-pro
BLACKBOX_VIDEO_MODEL=veo-2

# Local open-source Voicebox service (jamiepine/voicebox)
VOICEBOX_BASE_URL=http://127.0.0.1:17493
VOICEBOX_NARRATOR_PROFILE_ID=
VOICEBOX_MISSION_PROFILE_ID=
VOICEBOX_CINEMATIC_PROFILE_ID=
VOICEBOX_NPC_PROFILE_ID=
